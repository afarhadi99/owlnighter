{
  "name": "@owlnighter/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Drizzle schema + typed client over Supabase Postgres. SQL migrations live in infra/sql.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "node ./scripts/apply-sql.mjs",
    "seed:admin": "node ./scripts/seed-admin-accounts.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2"
  }
}
