# ============================================================
# owlnighter — environment template
# Copy to `.env` and fill in. NEVER commit `.env`.
# ============================================================

# --- App / server ---
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=8787
API_PUBLIC_URL=http://localhost:8787
LOG_LEVEL=info

# --- AI providers (developer-supplied keys, BACKEND ONLY) ---
# NOTE: the AI Tutor API is now the default provider, but its key is NOT set here.
# Configure the AI Tutor API key in the ADMIN PANEL → AI Providers (stored in the
# app_settings table), not in this file. Every task is provider-overridable there;
# a task routed to AI Tutor API with no workflow id yet falls back to Gemini — see
# docs/ai-tutor-workflows/README.md.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Groq Qwen 3.6 — fast, JSON object mode (no strict schema). App validates + retries.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b

# --- Deepgram TTS (backend only; pre-generation + caching) ---
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# --- Supabase (LOCAL for now) ---
# Point these at a local Supabase (`supabase start`) or a hosted project.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL must match whatever Postgres you run. `pnpm setup` / `scripts/setup.*`
# start a pgvector container and pin this to 127.0.0.1:55432 automatically.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Google OAuth (Google sign-in in the mobile app) ---
# Optional — only needed if you want "Sign in with Google" to work. See
# docs/SETUP.md "Google sign-in" for how to create these and enable the
# provider on your local Supabase Auth (GoTrue).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Catalog sources ---
GOOGLE_BOOKS_API_KEY=
OPEN_LIBRARY_BASE_URL=https://openlibrary.org

# --- Push (FCM) — LOCAL placeholder ---
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# --- Grounding thresholds ---
GROUNDING_AUTO_ACCEPT=0.85
GROUNDING_REVIEW_FLOOR=0.60

# --- Admin seed passwords (only used by `pnpm --filter @owlnighter/db run seed:admin`) ---
# NEVER commit real values here — placeholders only.
SEED_ADMIN_PASSWORD_RCOHEN=changeme
SEED_ADMIN_PASSWORD_NKUKAJ=changeme
SEED_ADMIN_PASSWORD_AFARHADI=changeme
