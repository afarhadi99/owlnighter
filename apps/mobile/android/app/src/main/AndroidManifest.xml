<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Networking: the app talks to the Fastify API over HTTP(S). -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Android 13+ runtime notification permission (firebase_messaging +
         flutter_local_notifications nightly reminders). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:label="owlnighter"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />

            <!-- Custom-scheme deep link: readingpath://plan/{planId}/step/{stepId}
                 (see services/deep_links/deep_links.dart). Resolved by go_router. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="readingpath"/>
            </intent-filter>

            <!-- Universal / App Link: https://<APP_LINK_HOST>/plan/... .
                 autoVerify enables Android App Links; host mirrors the
                 APP_LINK_HOST dart-define default (app.example.com). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https"
                    android:host="app.example.com"
                    android:pathPrefix="/plan"/>
            </intent-filter>

            <!-- Supabase Auth OAuth (Google) redirect callback. supabase_flutter
                 listens for this internally once Supabase.initialize has run
                 (see AuthRepositoryImpl); it must also be added to the Supabase
                 project's "Additional Redirect URLs". -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="owlnighterauth" android:host="login-callback"/>
            </intent-filter>
        </activity>

        <!-- Dynamic launcher icon (owl mood): four activity-alias entries all
             targeting MainActivity, each with a different android:icon. Exactly
             one is enabled at a time via PackageManager.setComponentEnabledSetting
             (see AppIconSwitcher.kt) — this is how the home-screen launcher icon
             changes, distinct from the ReadingWidgetProvider home-screen widget
             above. IconIdle is the default-enabled alias, matching the app's
             out-of-the-box icon. -->
        <activity-alias
            android:name=".IconIdle"
            android:targetActivity=".MainActivity"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconWorried"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_worried">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconAngry"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_angry">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconCheer"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_happy">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <!-- Home-screen reading widget (ReadingWidgetProvider.kt). onUpdate
             reads cached reading state from the home_widget prefs and redraws;
             tapping opens MainActivity. -->
        <receiver
            android:name=".ReadingWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/reading_widget_info" />
        </receiver>

        <!-- FCM: the channel a background/terminated remote push is posted to
             when the payload has no explicit channel. Must match the 'nightly'
             channel created by flutter_local_notifications (see
             services/notifications/notification_scheduler.dart). The
             FirebaseMessagingService is contributed by the firebase_messaging
             plugin's own manifest and merged automatically — no manual
             <service> declaration is needed here. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="nightly" />

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
