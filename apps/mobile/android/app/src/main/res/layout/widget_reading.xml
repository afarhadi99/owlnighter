<?xml version="1.0" encoding="utf-8"?>
<!-- owlnighter reading widget. Owl silhouette on the left, state copy on the
     right, with a small accent glyph (moon / flame / check) that the provider
     swaps per state. Text colors are baked here (brand ink / muted ink); the
     background drawable is set at runtime by ReadingWidgetProvider. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg_day"
    android:padding="14dp">

    <ImageView
        android:id="@+id/widget_owl"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginEnd="14dp"
        android:src="@drawable/owl_glyph"
        android:contentDescription="Owl" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/widget_accent"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="7dp"
                android:src="@drawable/accent_moon"
                android:contentDescription="Reading state" />

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F4F5FB"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Tonight's reading is waiting" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="#A6ACD6"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Settle in whenever you're ready." />
    </LinearLayout>
</LinearLayout>
