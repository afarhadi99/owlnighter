{
  "name": "@owlnighter/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify + TypeScript API for owlnighter. Implements the ENDPOINTS contract registry.",
  "license": "MIT",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.2",
    "@owlnighter/ai": "workspace:*",
    "@owlnighter/contracts": "workspace:*",
    "@owlnighter/db": "workspace:*",
    "@owlnighter/jobs": "workspace:*",
    "@owlnighter/shared": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "postgres": "^3.4.5",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
